# PersonaX v3 — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git

# ── DATABASE ──────────────────────────────
PX_DB_HOST=localhost
PX_DB_NAME=personax
PX_DB_USER=personax_user
PX_DB_PASS=change_this_password
PX_DB_PORT=3306

# ── SECURITY ──────────────────────────────
# Generate: openssl rand -base64 32
PX_APP_KEY=change_this_to_32_char_random_key_!

# ── ENVIRONMENT ───────────────────────────
# development | production
PX_ENV=production

# ── AI PROVIDERS ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=AIzaSy...

# ── EMAIL (SMTP) ──────────────────────────
PX_SMTP_HOST=smtp.gmail.com
PX_SMTP_PORT=587
PX_SMTP_USER=you@gmail.com
PX_SMTP_PASS=your_app_password_here
PX_SMTP_FROM=noreply@yourdomain.com

# ── PYTHON AI SERVICE ─────────────────────
# Generate: openssl rand -hex 32
PX_PY_URL=http://127.0.0.1:5050
PX_PY_KEY=change_this_internal_service_key
PX_PY_PORT=5050
